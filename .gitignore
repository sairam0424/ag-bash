# Dependencies
**/node_modules
**/.node_modules
**/.pnpm-store
**/.npm-cache
package-lock.json
# Ignore example/nested lockfiles but keep root
examples/**/pnpm-lock.yaml
packages/**/pnpm-lock.yaml

# Build Artifacts
**/dist
**/coverage
!packages/bash/src/security/fuzzing/coverage
**/*.parsed.json
packages/bash/src/commands/python3/worker.js
packages/bash/src/commands/js-exec/worker.js

# Environment and Secrets
.env
.env.local
.env.*.local
.npmrc

# Editor and System
.DS_Store
.vscode
.idea
.claude/settings.local.json
.env
.env.*

# Coverage is emitted per-package (e.g. packages/bash/coverage) by the CI
# coverage job and local runs — ignore it everywhere, not just at the root.
dist
/coverage
coverage/
packages/*/coverage
# Package tarballs produced by `pnpm pack` (install-smoke / pack-contents checks)
*.tgz

# Temporary and Logs
tmp-tap/
publish-tmp/
scratch/
debug-*.ts
# Don't ignore .test.sh or .test.ts unless they start with debug/test prefix
test-output/
fuzz-*.log
*.cpuprofile
profile-*.mjs
bench-*.mjs
todo/
.docs-test-tmp/

tsconfig.tsbuildinfo

# Ag-Bash Vendor & Artifacts
packages/bash/src/parser/vendor/
packages/bash/vendor/
packages/bash/dist_test/
test_output.txt

# Example Lockfiles (Dynamic/Untracked)
examples/*/pnpm-lock.yaml

# Perf-bench CI artifacts (the committed baseline is bench-baseline.json).
# bench:ci writes bench-results.json; bench:ci:multi writes the numbered
# best-of-N reports (bench-results.1.json, …) that bench-check compares.
packages/bash/bench-results.json
packages/bash/bench-results.*.json

# Private working notes (daily logs) — never commit
scratch-pad/
