{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@ag-bash/bash": ["../../packages/bash/src/index"],
      "@ag-bash/bash/browser": ["../../packages/bash/src/browser"]
    }
  },
  "include": ["*.ts", "../../packages/bash/src/**/*.ts"],
  "exclude": ["node_modules"]
}
