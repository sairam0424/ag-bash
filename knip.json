{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/index.ts!",
    "src/browser.ts!",
    "src/cli/ag-bash.ts!",
    "src/vitest-setup.ts",
    "src/comparison-tests/vitest.setup.ts",
    "vitest.config.ts",
    "vitest.comparison.config.ts"
  ],
  "project": ["src/**/*.ts"],
  "ignore": [
    "src/spec-tests/**",
    "src/banned-patterns-test.ts",
    "src/security/fuzzing/**"
  ],
  "ignoreBinaries": ["tsx"],
  "rules": {
    "unlisted": "off",
    "unresolved": "off",
    "optionalPeerDependencies": "off",
    "types": "off"
  }
}
