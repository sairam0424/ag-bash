{
  "name": "ag-bash-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "publish:all": "bash scripts/publish.sh",
    "publish:dry-run": "bash scripts/publish.sh --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@types/node": "^25.0.3",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-builder@<1.1.7": ">=1.1.7",
      "sanitize-html@2.17.3": ">=2.17.4"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
