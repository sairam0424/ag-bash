{
  "name": "ag-bash-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "check:version-sync": "node scripts/check-version-sync.js",
    "check:pack-contents": "node scripts/check-pack-contents.js",
    "publish:all": "bash scripts/publish.sh",
    "publish:dry-run": "bash scripts/publish.sh --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.0.3",
    "esbuild": "^0.27.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-builder@<1.1.7": ">=1.1.7",
      "sanitize-html@2.17.3": ">=2.17.4",
      "esbuild@<0.28.1": ">=0.28.1"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
