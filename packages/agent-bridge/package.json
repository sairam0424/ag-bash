{
  "name": "@ag-bash/agent-bridge",
  "version": "6.0.2",
  "description": "Terminal UI bridge for Ag-Bash — streams AI-agent output and tool calls to xterm.js-compatible terminals via pluggable adapters (SSE/HTTP fetch, custom WebSocket).",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ag-bash",
    "agentic",
    "terminal",
    "bridge"
  ],
  "homepage": "https://github.com/sairam0424/ag-bash/tree/main/packages/agent-bridge#readme",
  "bugs": {
    "url": "https://github.com/sairam0424/ag-bash/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sairam0424/ag-bash.git",
    "directory": "packages/agent-bridge"
  },
  "author": "Ag-Bash",
  "license": "Apache-2.0",
  "dependencies": {
    "@ag-bash/bash": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
